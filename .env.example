# 複製這份檔案為 .env 只是方便自己對照用；
# 實際部署到 Render 時，這些變數要設定在 Render Dashboard 的 Environment 頁籤，
# 不要把 .env 檔案本身放進 Git。

# --- 資料庫（用 Supabase 的話，去 Project Settings > Database 複製連線字串）---
DATABASE_URL=postgres://postgres:your-password@db.xxxxxxxx.supabase.co:5432/postgres?sslmode=require

# 如果不想用整包 DATABASE_URL，也可以分開填：
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=quizdb
# DB_USER=postgres
# DB_PASS=
# DB_SSLMODE=require

# --- Google OAuth（去 Google Cloud Console > API 和服務 > 憑證 建立）---
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxx
GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth_google_callback.php

# 本機用 http 測試時設 false，正式環境（Render）一定要 true
FORCE_HTTPS=true
